{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "icycon/manage.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "icycon/manage.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "icycon.settings"
  }
}
